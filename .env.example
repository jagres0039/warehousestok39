# ---- Application ----
NODE_ENV=development

# Public app URL (used in emails, callbacks, etc.)
APP_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
POSTGRES_USER=warehouse
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=warehousestok39

# Connection string used by Prisma. In docker-compose this points at the `db` service.
DATABASE_URL=postgresql://warehouse:change_me_in_production@localhost:5432/warehousestok39?schema=public

# ---- Auth (NextAuth) ----
# Generate via: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_long_random_string
NEXTAUTH_URL=http://localhost:3000

# ---- i18n ----
DEFAULT_LOCALE=id
SUPPORTED_LOCALES=id,en

# ---- Deployment domain (used by Caddy in production) ----
PUBLIC_DOMAIN=warehousestok39.example.com
ACME_EMAIL=admin@example.com
