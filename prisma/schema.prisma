// Prisma schema for warehousestok39
// Multi-tenant SaaS warehouse inventory management.
// Sprint 1: foundational tenancy models (Organization, User, Membership)
// and document-numbering config. Domain tables (Item, GoodsReceipt, etc.)
// land in subsequent sprints.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum ResetPolicy {
  never
  yearly
  monthly
}

enum DocType {
  GOODS_RECEIPT
  GOODS_ISSUE
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  STOCK_OPNAME
  PURCHASE_ORDER
  SALES_ORDER
  INVOICE
}

enum DocStatus {
  POSTED
  CANCELED
}

enum StockMoveType {
  RECEIPT
  ISSUE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RECEIPT_REVERSAL
  ISSUE_REVERSAL
  ADJUSTMENT_REVERSAL
  TRANSFER_OUT
  TRANSFER_IN
  TRANSFER_REVERSAL
  OPNAME_IN
  OPNAME_OUT
  OPNAME_REVERSAL
}

enum OpnameStatus {
  DRAFT
  POSTED
  CANCELED
}

enum AdjustmentDirection {
  IN
  OUT
}

model Organization {
  id            String   @id @default(cuid())
  // URL-safe slug, also used as ORG code in document numbering.
  slug          String   @unique
  name          String
  address       String?
  npwp          String?
  logoUrl       String?
  currency      String   @default("IDR")
  timezone      String   @default("Asia/Jakarta")
  defaultLocale String   @default("id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships     Membership[]
  invitations     Invitation[]
  docNumberConfig DocNumberConfig[]
  categories      Category[]
  units           Unit[]
  items           Item[]
  suppliers       Supplier[]
  customers       Customer[]
  warehouses      Warehouse[]
  goodsReceipts   GoodsReceipt[]
  goodsIssues     GoodsIssue[]
  adjustments     StockAdjustment[]
  transfers       StockTransfer[]
  opnames         StockOpname[]
  itemBatches     ItemBatch[]
  notifications   Notification[]
  alertCheckRuns  AlertCheckRun[]
  ledgerEntries   StockLedger[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  locale       String   @default("id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]

  @@index([email])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role     @default(OPERATOR)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// Pending team invitation. One row per outstanding invite; once accepted or
// revoked the row stays as audit trail (acceptedAt / revokedAt set). A single
// pending row per (organizationId, email) is enforced in service code; we
// don't add a partial unique index because Prisma doesn't model them well.
model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role      @default(OPERATOR)
  // Random URL-safe token used in the accept link.
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedById   String?
  revokedAt      DateTime?
  revokedById    String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@index([organizationId, acceptedAt, revokedAt])
}

// One row per (organization, document type). Holds the template the tenant
// configured plus the current counter and the period bucket the counter
// belongs to (so we know when to reset it).
model DocNumberConfig {
  id             String      @id @default(cuid())
  organizationId String
  docType        DocType
  template       String
  resetPolicy    ResetPolicy @default(yearly)
  currentCounter Int         @default(0)
  counterPeriod  String      @default("all")
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, docType])
}

// --- Master data ----------------------------------------------------------
//
// All master-data tables are tenant-scoped via organizationId, soft-deletable
// via isActive (so historical transactions keep referencing real rows), and
// use a per-tenant unique code/slug. Hard deletes are never exposed to users.

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  // Short code shown on labels (PCS, BOX, KG, L, ...).
  code           String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Item {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  name           String
  description    String?
  // Optional barcode/QR — uniqueness is per tenant so two tenants can share GTINs.
  barcode        String?
  categoryId     String?
  unitId         String
  // Stored as Decimal(18,3) to support fractional units (e.g. 0.250 kg).
  minStock       Decimal  @default(0) @db.Decimal(18, 3)
  imageUrl       String?
  // When true, every stock movement for this item must reference an ItemBatch
  // (lot tracking). False keeps the legacy item-only behaviour. Sprint 12.
  tracksBatch    Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category        Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit            Unit                  @relation(fields: [unitId], references: [id], onDelete: Restrict)
  batches         ItemBatch[]
  receiptLines    GoodsReceiptLine[]
  issueLines      GoodsIssueLine[]
  adjustmentLines StockAdjustmentLine[]
  transferLines   StockTransferLine[]
  opnameLines     StockOpnameLine[]
  notifications   Notification[]
  ledgerEntries   StockLedger[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  address        String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  goodsReceipts GoodsReceipt[]
  goodsIssues   GoodsIssue[]
  adjustments   StockAdjustment[]
  transfersFrom StockTransfer[]   @relation("StockTransferFromWarehouse")
  transfersTo   StockTransfer[]   @relation("StockTransferToWarehouse")
  opnames       StockOpname[]
  notifications Notification[]
  ledgerEntries StockLedger[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

// --- Transactions --------------------------------------------------------
//
// All transaction tables are tenant-scoped. Headers are append-only: once
// POSTED they can be CANCELED (which writes reversal entries to StockLedger)
// but never edited in place. Document numbers come from DocNumberConfig.

model GoodsReceipt {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  supplierId     String?
  note           String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        GoodsReceiptLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model GoodsReceiptLine {
  id        String  @id @default(cuid())
  receiptId String
  itemId    String
  // Required when item.tracksBatch = true. Null for non-batch items.
  batchId   String?
  qty       Decimal @db.Decimal(18, 3)
  note      String?

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  item    Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch   ItemBatch?   @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([itemId])
  @@index([batchId])
}

model GoodsIssue {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  customerId     String?
  note           String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        GoodsIssueLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model GoodsIssueLine {
  id      String  @id @default(cuid())
  issueId String
  itemId  String
  batchId String?
  qty     Decimal @db.Decimal(18, 3)
  note    String?

  issue GoodsIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  item  Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch ItemBatch? @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@index([itemId])
  @@index([batchId])
}

model StockAdjustment {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  reason         String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        StockAdjustmentLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockAdjustmentLine {
  id           String              @id @default(cuid())
  adjustmentId String
  itemId       String
  batchId      String?
  direction    AdjustmentDirection
  qty          Decimal             @db.Decimal(18, 3)
  note         String?

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch      ItemBatch?      @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([adjustmentId])
  @@index([itemId])
  @@index([batchId])
}

// Append-only stock movement log. On-hand stock for (item, warehouse) is
// SUM(qtyDelta) across this table. Reversals are written as new rows so the
// audit trail is preserved; no row in this table is ever updated or deleted.
model StockLedger {
  id             String        @id @default(cuid())
  organizationId String
  occurredAt     DateTime      @default(now())
  itemId         String
  warehouseId    String
  // Optional reference to the lot/batch this movement applies to. Null for
  // items where tracksBatch = false. Set for every movement of a batch-tracked
  // item; on-hand-per-batch is SUM(qtyDelta) grouped by (itemId, warehouseId,
  // batchId).
  batchId        String?
  // Signed delta in the item's unit. Positive = stock in, negative = stock out.
  qtyDelta       Decimal       @db.Decimal(18, 3)
  moveType       StockMoveType
  refType        String
  refId          String
  note           String?
  createdById    String
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  batch        ItemBatch?   @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([organizationId, itemId, warehouseId])
  @@index([organizationId, itemId, warehouseId, batchId])
  @@index([organizationId, occurredAt])
  @@index([refType, refId])
}

// --- Sprint 11: Stock Transfer & Stock Opname ----------------------------
//
// Transfers move stock between two warehouses inside the same tenant. Posting
// a transfer writes two ledger entries per line (TRANSFER_OUT at the source,
// TRANSFER_IN at the destination) inside a single Prisma transaction, so the
// total qty across the org is invariant.
//
// Opnames are physical stock counts. Creating a draft snapshots the current
// on-hand for every active item in the chosen warehouse (systemQty). Operators
// then fill in countedQty per line. Posting writes one ledger entry per
// non-zero variance line (OPNAME_IN if positive, OPNAME_OUT if negative) using
// the difference between the counted figure and current on-hand at post time
// (not the snapshot) so concurrent transactions between snapshot and post are
// honoured -- the count is treated as the new authoritative on-hand.

model StockTransfer {
  id              String    @id @default(cuid())
  organizationId  String
  docNo           String
  occurredAt      DateTime  @default(now())
  fromWarehouseId String
  toWarehouseId   String
  note            String?
  status          DocStatus @default(POSTED)
  createdById     String
  canceledAt      DateTime?
  canceledById    String?
  cancelReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("StockTransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse           @relation("StockTransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  lines         StockTransferLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockTransferLine {
  id         String  @id @default(cuid())
  transferId String
  itemId     String
  // Source batch (and destination — transfers preserve batch identity).
  batchId    String?
  qty        Decimal @db.Decimal(18, 3)
  note       String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch    ItemBatch?    @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([itemId])
  @@index([batchId])
}

model StockOpname {
  id             String       @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime     @default(now())
  warehouseId    String
  note           String?
  status         OpnameStatus @default(DRAFT)
  createdById    String
  postedAt       DateTime?
  postedById     String?
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        StockOpnameLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockOpnameLine {
  id          String  @id @default(cuid())
  opnameId    String
  itemId      String
  // Optional batch reference. Non-batch items always have batchId = null and
  // the (opnameId, itemId, batchId) tuple has at most one row per item.
  // Batch-tracked items get one row per (item, batch) pair.
  batchId     String?
  // Snapshot of on-hand at the moment the draft was created.
  systemQty   Decimal @db.Decimal(18, 3)
  // Quantity counted physically. Defaults to systemQty until edited.
  countedQty  Decimal @db.Decimal(18, 3)
  // countedQty - systemQty. Stored for fast reporting; recomputed on edit.
  varianceQty Decimal @db.Decimal(18, 3)
  note        String?

  opname StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  item   Item        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch  ItemBatch?  @relation(fields: [batchId], references: [id], onDelete: Restrict)

  // batchId may be null for non-batch items, so we use a partial-style unique
  // by including batchId. Postgres treats (X, Y, NULL) as distinct from
  // (X, Y, NULL) which makes the unique permissive for nulls — but per-item
  // we ensure single row in application code. For batch items each
  // (opnameId, itemId, batchId) tuple is naturally unique because every
  // batch has a non-null id.
  @@unique([opnameId, itemId, batchId])
  @@index([opnameId])
  @@index([itemId])
  @@index([batchId])
}

// --- Sprint 12: Lot / Batch tracking + Notifications ---------------------
//
// ItemBatch is per (item, batchCode). batchCode is supplied by the operator at
// receipt time; we don't auto-generate it because suppliers usually print real
// lot numbers on the carton. expiryDate is optional for non-perishables.
// On-hand per batch is computed by summing StockLedger.qtyDelta filtered by
// (itemId, warehouseId, batchId). Batches are never deleted; isActive is the
// soft-disable flag, but movements can still reference an inactive batch.

model ItemBatch {
  id             String    @id @default(cuid())
  organizationId String
  itemId         String
  batchCode      String
  mfgDate        DateTime?
  expiryDate     DateTime?
  // Optional cost reference for inventory valuation; not used for math yet.
  costPrice      Decimal?  @db.Decimal(18, 4)
  note           String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item            Item                  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  receiptLines    GoodsReceiptLine[]
  issueLines      GoodsIssueLine[]
  adjustmentLines StockAdjustmentLine[]
  transferLines   StockTransferLine[]
  opnameLines     StockOpnameLine[]
  notifications   Notification[]
  ledgerEntries   StockLedger[]

  @@unique([organizationId, itemId, batchCode])
  @@index([organizationId, itemId, isActive])
  @@index([organizationId, expiryDate])
}

enum NotificationType {
  LOW_STOCK
  EXPIRING_SOON
  EXPIRED
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

// In-app notifications. The cron endpoint upserts one row per
// (organizationId, type, itemId, batchId, dateBucket) so re-running the check
// the same day doesn't fan out duplicates. Marking as read is a per-row flag;
// when the underlying condition resolves (stock recovers, batch consumed) the
// row stays for audit but isResolved gets flipped.
model Notification {
  id             String               @id @default(cuid())
  organizationId String
  type           NotificationType
  severity       NotificationSeverity @default(WARNING)
  itemId         String?
  batchId        String?
  warehouseId    String?
  // Idempotency: at most one row per (org, type, item, batch, dateBucket).
  // dateBucket is YYYY-MM-DD of when the alert was first raised.
  dateBucket     String
  // Snapshot fields used to render the alert without re-querying.
  title          String
  body           String
  // Numeric payload for sorting/filtering (e.g. days-to-expiry, shortage qty).
  metricValue    Decimal?             @db.Decimal(18, 3)
  isRead         Boolean              @default(false)
  readAt         DateTime?
  isResolved     Boolean              @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item?        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch        ItemBatch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([organizationId, type, itemId, batchId, dateBucket])
  @@index([organizationId, isRead, isResolved])
  @@index([organizationId, createdAt])
}

// Audit row written every time the cron endpoint runs the alert sweep, so
// admins can see when alerts were last refreshed and how many were created.
model AlertCheckRun {
  id             String    @id @default(cuid())
  organizationId String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  // Counts populated when the run finishes.
  itemsScanned   Int       @default(0)
  batchesScanned Int       @default(0)
  alertsCreated  Int       @default(0)
  alertsResolved Int       @default(0)
  triggeredById  String?
  triggerSource  String    @default("cron")
  errorMessage   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
}
