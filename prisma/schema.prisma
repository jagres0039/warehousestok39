// Prisma schema for warehousestok39
// Multi-tenant SaaS warehouse inventory management.
// Sprint 1: foundational tenancy models (Organization, User, Membership)
// and document-numbering config. Domain tables (Item, GoodsReceipt, etc.)
// land in subsequent sprints.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum ResetPolicy {
  never
  yearly
  monthly
}

enum DocType {
  GOODS_RECEIPT
  GOODS_ISSUE
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  STOCK_OPNAME
  PURCHASE_ORDER
  SALES_ORDER
  INVOICE
}

enum DocStatus {
  POSTED
  CANCELED
}

enum StockMoveType {
  RECEIPT
  ISSUE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RECEIPT_REVERSAL
  ISSUE_REVERSAL
  ADJUSTMENT_REVERSAL
  TRANSFER_OUT
  TRANSFER_IN
  TRANSFER_REVERSAL
  OPNAME_IN
  OPNAME_OUT
  OPNAME_REVERSAL
}

enum OpnameStatus {
  DRAFT
  POSTED
  CANCELED
}

enum AdjustmentDirection {
  IN
  OUT
}

model Organization {
  id            String   @id @default(cuid())
  // URL-safe slug, also used as ORG code in document numbering.
  slug          String   @unique
  name          String
  address       String?
  npwp          String?
  logoUrl       String?
  currency      String   @default("IDR")
  timezone      String   @default("Asia/Jakarta")
  defaultLocale String   @default("id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships     Membership[]
  invitations     Invitation[]
  docNumberConfig DocNumberConfig[]
  categories      Category[]
  units           Unit[]
  items           Item[]
  suppliers       Supplier[]
  customers       Customer[]
  warehouses      Warehouse[]
  goodsReceipts   GoodsReceipt[]
  goodsIssues     GoodsIssue[]
  adjustments     StockAdjustment[]
  transfers       StockTransfer[]
  opnames         StockOpname[]
  ledgerEntries   StockLedger[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  locale       String   @default("id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]

  @@index([email])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role     @default(OPERATOR)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// Pending team invitation. One row per outstanding invite; once accepted or
// revoked the row stays as audit trail (acceptedAt / revokedAt set). A single
// pending row per (organizationId, email) is enforced in service code; we
// don't add a partial unique index because Prisma doesn't model them well.
model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role      @default(OPERATOR)
  // Random URL-safe token used in the accept link.
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedById   String?
  revokedAt      DateTime?
  revokedById    String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@index([organizationId, acceptedAt, revokedAt])
}

// One row per (organization, document type). Holds the template the tenant
// configured plus the current counter and the period bucket the counter
// belongs to (so we know when to reset it).
model DocNumberConfig {
  id             String      @id @default(cuid())
  organizationId String
  docType        DocType
  template       String
  resetPolicy    ResetPolicy @default(yearly)
  currentCounter Int         @default(0)
  counterPeriod  String      @default("all")
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, docType])
}

// --- Master data ----------------------------------------------------------
//
// All master-data tables are tenant-scoped via organizationId, soft-deletable
// via isActive (so historical transactions keep referencing real rows), and
// use a per-tenant unique code/slug. Hard deletes are never exposed to users.

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  // Short code shown on labels (PCS, BOX, KG, L, ...).
  code           String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Item {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  name           String
  description    String?
  // Optional barcode/QR — uniqueness is per tenant so two tenants can share GTINs.
  barcode        String?
  categoryId     String?
  unitId         String
  // Stored as Decimal(18,3) to support fractional units (e.g. 0.250 kg).
  minStock       Decimal  @default(0) @db.Decimal(18, 3)
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category        Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit            Unit                  @relation(fields: [unitId], references: [id], onDelete: Restrict)
  receiptLines    GoodsReceiptLine[]
  issueLines      GoodsIssueLine[]
  adjustmentLines StockAdjustmentLine[]
  transferLines   StockTransferLine[]
  opnameLines     StockOpnameLine[]
  ledgerEntries   StockLedger[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  address        String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  goodsReceipts GoodsReceipt[]
  goodsIssues   GoodsIssue[]
  adjustments   StockAdjustment[]
  transfersFrom StockTransfer[]   @relation("StockTransferFromWarehouse")
  transfersTo   StockTransfer[]   @relation("StockTransferToWarehouse")
  opnames       StockOpname[]
  ledgerEntries StockLedger[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

// --- Transactions --------------------------------------------------------
//
// All transaction tables are tenant-scoped. Headers are append-only: once
// POSTED they can be CANCELED (which writes reversal entries to StockLedger)
// but never edited in place. Document numbers come from DocNumberConfig.

model GoodsReceipt {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  supplierId     String?
  note           String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        GoodsReceiptLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model GoodsReceiptLine {
  id        String  @id @default(cuid())
  receiptId String
  itemId    String
  qty       Decimal @db.Decimal(18, 3)
  note      String?

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  item    Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([itemId])
}

model GoodsIssue {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  customerId     String?
  note           String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        GoodsIssueLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model GoodsIssueLine {
  id      String  @id @default(cuid())
  issueId String
  itemId  String
  qty     Decimal @db.Decimal(18, 3)
  note    String?

  issue GoodsIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  item  Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@index([itemId])
}

model StockAdjustment {
  id             String    @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime  @default(now())
  warehouseId    String
  reason         String?
  status         DocStatus @default(POSTED)
  createdById    String
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        StockAdjustmentLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockAdjustmentLine {
  id           String              @id @default(cuid())
  adjustmentId String
  itemId       String
  direction    AdjustmentDirection
  qty          Decimal             @db.Decimal(18, 3)
  note         String?

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([adjustmentId])
  @@index([itemId])
}

// Append-only stock movement log. On-hand stock for (item, warehouse) is
// SUM(qtyDelta) across this table. Reversals are written as new rows so the
// audit trail is preserved; no row in this table is ever updated or deleted.
model StockLedger {
  id             String        @id @default(cuid())
  organizationId String
  occurredAt     DateTime      @default(now())
  itemId         String
  warehouseId    String
  // Signed delta in the item's unit. Positive = stock in, negative = stock out.
  qtyDelta       Decimal       @db.Decimal(18, 3)
  moveType       StockMoveType
  refType        String
  refId          String
  note           String?
  createdById    String
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([organizationId, itemId, warehouseId])
  @@index([organizationId, occurredAt])
  @@index([refType, refId])
}

// --- Sprint 11: Stock Transfer & Stock Opname ----------------------------
//
// Transfers move stock between two warehouses inside the same tenant. Posting
// a transfer writes two ledger entries per line (TRANSFER_OUT at the source,
// TRANSFER_IN at the destination) inside a single Prisma transaction, so the
// total qty across the org is invariant.
//
// Opnames are physical stock counts. Creating a draft snapshots the current
// on-hand for every active item in the chosen warehouse (systemQty). Operators
// then fill in countedQty per line. Posting writes one ledger entry per
// non-zero variance line (OPNAME_IN if positive, OPNAME_OUT if negative) using
// the difference between the counted figure and current on-hand at post time
// (not the snapshot) so concurrent transactions between snapshot and post are
// honoured -- the count is treated as the new authoritative on-hand.

model StockTransfer {
  id              String    @id @default(cuid())
  organizationId  String
  docNo           String
  occurredAt      DateTime  @default(now())
  fromWarehouseId String
  toWarehouseId   String
  note            String?
  status          DocStatus @default(POSTED)
  createdById     String
  canceledAt      DateTime?
  canceledById    String?
  cancelReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("StockTransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse           @relation("StockTransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  lines         StockTransferLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockTransferLine {
  id         String  @id @default(cuid())
  transferId String
  itemId     String
  qty        Decimal @db.Decimal(18, 3)
  note       String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([itemId])
}

model StockOpname {
  id             String       @id @default(cuid())
  organizationId String
  docNo          String
  occurredAt     DateTime     @default(now())
  warehouseId    String
  note           String?
  status         OpnameStatus @default(DRAFT)
  createdById    String
  postedAt       DateTime?
  postedById     String?
  canceledAt     DateTime?
  canceledById   String?
  cancelReason   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        StockOpnameLine[]

  @@unique([organizationId, docNo])
  @@index([organizationId, occurredAt])
  @@index([organizationId, status])
}

model StockOpnameLine {
  id          String  @id @default(cuid())
  opnameId    String
  itemId      String
  // Snapshot of on-hand at the moment the draft was created.
  systemQty   Decimal @db.Decimal(18, 3)
  // Quantity counted physically. Defaults to systemQty until edited.
  countedQty  Decimal @db.Decimal(18, 3)
  // countedQty - systemQty. Stored for fast reporting; recomputed on edit.
  varianceQty Decimal @db.Decimal(18, 3)
  note        String?

  opname StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  item   Item        @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([opnameId, itemId])
  @@index([opnameId])
  @@index([itemId])
}
