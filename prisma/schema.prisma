// Prisma schema for warehousestok39
// Multi-tenant SaaS warehouse inventory management.
// Sprint 1: foundational tenancy models (Organization, User, Membership)
// and document-numbering config. Domain tables (Item, GoodsReceipt, etc.)
// land in subsequent sprints.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum ResetPolicy {
  never
  yearly
  monthly
}

enum DocType {
  GOODS_RECEIPT
  GOODS_ISSUE
  STOCK_ADJUSTMENT
  PURCHASE_ORDER
  SALES_ORDER
  INVOICE
}

model Organization {
  id            String   @id @default(cuid())
  // URL-safe slug, also used as ORG code in document numbering.
  slug          String   @unique
  name          String
  address       String?
  npwp          String?
  logoUrl       String?
  currency      String   @default("IDR")
  timezone      String   @default("Asia/Jakarta")
  defaultLocale String   @default("id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships     Membership[]
  docNumberConfig DocNumberConfig[]
  categories      Category[]
  units           Unit[]
  items           Item[]
  suppliers       Supplier[]
  customers       Customer[]
  warehouses      Warehouse[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  locale       String   @default("id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]

  @@index([email])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(OPERATOR)
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// One row per (organization, document type). Holds the template the tenant
// configured plus the current counter and the period bucket the counter
// belongs to (so we know when to reset it).
model DocNumberConfig {
  id             String      @id @default(cuid())
  organizationId String
  docType        DocType
  template       String
  resetPolicy    ResetPolicy @default(yearly)
  currentCounter Int         @default(0)
  counterPeriod  String      @default("all")
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, docType])
}

// --- Master data ----------------------------------------------------------
//
// All master-data tables are tenant-scoped via organizationId, soft-deletable
// via isActive (so historical transactions keep referencing real rows), and
// use a per-tenant unique code/slug. Hard deletes are never exposed to users.

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  // Short code shown on labels (PCS, BOX, KG, L, ...).
  code           String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Item {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  name           String
  description    String?
  // Optional barcode/QR — uniqueness is per tenant so two tenants can share GTINs.
  barcode        String?
  categoryId     String?
  unitId         String
  // Stored as Decimal(18,3) to support fractional units (e.g. 0.250 kg).
  minStock       Decimal  @default(0) @db.Decimal(18, 3)
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  address        String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}
